#!/usr/bin/env bash
# Development mode: Rust server (port 3939) + SvelteKit dev server.
# By default vite binds :5173; when wrapped by `portless` it picks the port
# for us via $PORT and routes dbnyan-dev.localhost:1355 → vite.
set -e
cd "$(dirname "$0")/.."

if [ ! -d web/node_modules ]; then
	echo "→ installing web deps…"
	(cd web && bun install)
fi

echo "→ starting Rust server (background)…"
cargo run -p dbnyan-server &
SERVER_PID=$!

cleanup() {
	echo
	echo "→ stopping…"
	kill "$SERVER_PID" 2>/dev/null || true
	wait "$SERVER_PID" 2>/dev/null || true
	exit
}
trap cleanup INT TERM

VITE_PORT="${PORT:-5173}"
# Vite's default `--host` (localhost) resolves to IPv6 ::1 first on macOS,
# so portless — which connects via IPv4 127.0.0.1 — can't reach it and
# returns 502. Passing --host pins it to the interface portless expects.
VITE_HOST="${HOST:-localhost}"
echo "→ starting SvelteKit dev @ http://${VITE_HOST}:${VITE_PORT}"
cd web
exec bun run dev --port "$VITE_PORT" --host "$VITE_HOST"
